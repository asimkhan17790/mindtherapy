# Environment Variables for MindTherapy Backend

# Server Configuration
PORT=3001

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/mindtherapy
# For production, use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mindtherapy

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Firebase Configuration (for notifications - optional)
FIREBASE_PROJECT_ID=your-firebase-project-id